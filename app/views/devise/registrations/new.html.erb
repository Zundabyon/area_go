<% content_for :title, "新規登録 | AreaGo" %>

<div class="min-h-screen flex flex-col items-center justify-center bg-gradient-to-b from-water-800 to-water-950 px-4 py-12">
  <div class="w-full max-w-sm">
    <div class="text-center mb-8">
      <div class="w-16 h-16 bg-water-500 rounded-2xl flex items-center justify-center mx-auto mb-3 shadow-lg">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-9 h-9 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064" />
        </svg>
      </div>
      <h1 class="text-2xl font-bold text-white">AreaGo</h1>
      <p class="text-water-300 text-sm mt-1">アカウントを作成</p>
    </div>

    <div class="bg-white rounded-2xl shadow-xl p-6">
      <h2 class="text-lg font-semibold text-pebble-800 mb-5">新規登録</h2>

      <%= form_with(model: resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
        <% if resource.errors.any? %>
          <div class="mb-4 bg-red-50 border border-red-200 rounded-xl p-3 text-sm text-red-700">
            <% resource.errors.full_messages.each do |msg| %>
              <p><%= msg %></p>
            <% end %>
          </div>
        <% end %>

        <div class="space-y-4">
          <div>
            <%= f.label :username, "ニックネーム", class: "form-label" %>
            <%= f.text_field :username, autofocus: true, autocomplete: "nickname", class: "form-input" %>
          </div>
          <div>
            <%= f.label :email, "メールアドレス", class: "form-label" %>
            <%= f.email_field :email, autocomplete: "email", class: "form-input" %>
          </div>
          <div>
            <%= f.label :password, "パスワード（6文字以上）", class: "form-label" %>
            <%= f.password_field :password, autocomplete: "new-password", class: "form-input" %>
          </div>
          <div>
            <%= f.label :password_confirmation, "パスワード（確認）", class: "form-label" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-input" %>
          </div>
          <%= f.submit "アカウント作成", class: "btn-primary w-full text-center cursor-pointer mt-2" %>
        </div>
      <% end %>

      <div class="mt-4 text-center text-sm text-pebble-500">
        すでにアカウントをお持ちの方は
        <%= link_to "ログイン", new_session_path(resource_name), class: "text-water-600 font-medium hover:underline" %>
      </div>
    </div>
  </div>
</div>
