<% content_for :title, "施設登録 | AreaGo" %>

<div class="pt-2">
  <div class="flex items-center gap-3 mb-5">
    <%= link_to facilities_path, class: "text-water-600" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
    <% end %>
    <h1 class="page-title mb-0">施設を追加</h1>
  </div>

  <%= form_with model: @facility, class: "space-y-5" do |f| %>

    <%# ── Google Maps 検索（施設情報を自動入力） ── %>
    <div data-controller="map"
         data-map-mode-value="facility_search"
         data-map-api-key-value="<%= ENV['GOOGLE_MAPS_API_KEY'] %>">

      <%# 検索ボックス %>
      <div class="mb-3">
        <label class="form-label">施設名で検索</label>
        <input type="text"
               data-map-target="searchInput"
               class="form-input"
               placeholder="施設名・地名で検索...（例: フォレストスプリングス）">
        <p class="text-xs text-pebble-400 mt-1">
          候補を選択すると施設名・住所・電話番号などが自動入力されます
        </p>
      </div>

      <%# 地図 %>
      <div data-map-target="container"
           class="w-full rounded-xl overflow-hidden border border-pebble-200 mb-4"
           style="height: 240px;"
           data-turbo-cache="false"></div>

      <%# 自動入力される施設情報フィールド（地図コントローラーのターゲット） %>
      <div class="space-y-4">
        <div>
          <%= f.label :name, "施設名", class: "form-label" %>
          <%= f.text_field :name,
                class: "form-input",
                placeholder: "施設名",
                data: { "map-target": "facilityNameInput" } %>
        </div>
        <div>
          <%= f.label :address, "住所", class: "form-label" %>
          <%= f.text_field :address,
                class: "form-input",
                placeholder: "住所",
                data: { "map-target": "addressInput" } %>
        </div>
        <div>
          <%= f.label :prefecture, "都道府県", class: "form-label" %>
          <%= f.text_field :prefecture,
                class: "form-input",
                placeholder: "例: 東京都",
                data: { "map-target": "prefectureInput" } %>
        </div>
        <div>
          <%= f.label :phone_number, "電話番号", class: "form-label" %>
          <%= f.telephone_field :phone_number,
                class: "form-input",
                placeholder: "任意",
                data: { "map-target": "phoneInput" } %>
        </div>
        <div>
          <%= f.label :website_url, "Webサイト", class: "form-label" %>
          <%= f.url_field :website_url,
                class: "form-input",
                placeholder: "任意",
                data: { "map-target": "websiteInput" } %>
        </div>
        <div>
          <%= f.label :description, "施設メモ", class: "form-label" %>
          <%= f.text_area :description,
                rows: 3,
                class: "form-input",
                placeholder: "料金・営業時間・ポンド情報など（任意）" %>
        </div>
      </div>

      <%# 技術的な隠しフィールド（地図から自動セット） %>
      <%= f.hidden_field :latitude,  data: { "map-target": "latInput" } %>
      <%= f.hidden_field :longitude, data: { "map-target": "lngInput" } %>
      <%= f.hidden_field :place_id,  data: { "map-target": "placeIdInput" } %>
    </div>

    <%= f.submit "登録する", class: "btn-primary w-full text-center cursor-pointer" %>
  <% end %>
</div>
