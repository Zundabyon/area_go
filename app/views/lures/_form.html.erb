<%= form_with model: lure, class: "space-y-5" do |f| %>
  <% if lure.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-xl p-3 text-sm text-red-700">
      <% lure.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <%# ── メーカー → 種別 → ルアー名（3段階連動） ── %>
  <div
    data-controller="lure-select"
    data-lure-select-lures-value="<%= Lure::MANUFACTURERS.to_json %>"
  >

    <%# メーカー選択 %>
    <div class="mb-3">
      <%= f.label :manufacturer, "メーカー", class: "form-label" %>
      <%= f.select :manufacturer,
            [["メーカーを選択", ""]] + Lure::MANUFACTURER_NAMES.map { [_1, _1] },
            { selected: lure.manufacturer },
            class: "form-input",
            data: {
              "lure-select-target": "manufacturer",
              action: "change->lure-select#manufacturerChanged"
            }
      %>
    </div>

    <%# 種別選択 %>
    <div class="mb-3">
      <%= f.label :lure_type, "種別", class: "form-label" %>
      <%= f.select :lure_type,
            [["← 先にメーカーを選択", ""]],
            { selected: lure.lure_type },
            class: "form-input",
            disabled: lure.new_record?,
            data: {
              "lure-select-target": "lureType",
              action: "change->lure-select#lureTypeChanged"
            }
      %>
    </div>

    <%# ルアー名選択 %>
    <div>
      <%= f.label :name, "ルアー名", class: "form-label" %>
      <%= f.select :name,
            [["← 先に種別を選択", ""]],
            { selected: lure.name },
            class: "form-input",
            disabled: lure.new_record?,
            data: {
              "lure-select-target": "lureName"
            }
      %>
      <p class="text-xs text-pebble-400 mt-1">
        一覧にない場合は直接入力もできますわ →
        <%= f.text_field :name,
              class: "form-input mt-1",
              placeholder: "ルアー名を直接入力",
              data: { "lure-select-target": "lureNameInput" }
        %>
      </p>
    </div>
  </div>

  <%# カラー（表・裏） %>
  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :color_front, "表カラー", class: "form-label" %>
      <div class="flex items-center gap-2">
        <%= f.color_field :color_front, class: "w-10 h-10 rounded cursor-pointer border border-pebble-200" %>
        <span class="text-sm text-pebble-500">表（フロント）</span>
      </div>
    </div>
    <div>
      <%= f.label :color_back, "裏カラー", class: "form-label" %>
      <div class="flex items-center gap-2">
        <%= f.color_field :color_back, class: "w-10 h-10 rounded cursor-pointer border border-pebble-200" %>
        <span class="text-sm text-pebble-500">裏（バック）</span>
      </div>
    </div>
  </div>

  <%# ウェイト %>
  <div>
    <%= f.label :weight, "ウェイト（g）", class: "form-label" %>
    <%= f.number_field :weight, step: 0.1, min: 0, class: "form-input", placeholder: "例：2.5" %>
  </div>

  <%# 浮力（スプーン以外） %>
  <div data-controller="buoyancy-slider">
    <%= f.label :buoyancy, "浮力", class: "form-label" %>
    <div class="flex flex-col gap-2 mt-1">
      <% Lure::BUOYANCY_LABELS.each do |val, label| %>
        <label class="cursor-pointer inline-flex items-center gap-2 px-3 py-2 rounded-xl border-2 text-sm font-medium transition-colors select-none <%= lure.buoyancy == val ? 'border-water-500 bg-water-50 text-water-700' : 'border-pebble-200 bg-white text-pebble-600' %>"
               data-buoyancy-slider-target="btn"
               data-action="click->buoyancy-slider#select"
               data-selected="<%= lure.buoyancy == val %>">
          <%= f.radio_button :buoyancy, val, id: "buoyancy_#{val}",
                style: "position:absolute;opacity:0;width:0;height:0;overflow:hidden" %>
          <span class="text-sm"><%= label %></span>
        </label>
      <% end %>
    </div>
  </div>

  <%= f.submit lure.new_record? ? "ルアーを登録" : "更新する",
        class: "btn-primary w-full text-center cursor-pointer" %>
<% end %>