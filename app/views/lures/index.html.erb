<% content_for :title, "ルアー一覧 | AreaGo" %>

<div class="space-y-4 pt-2">
  <div class="flex items-center justify-between">
    <h1 class="page-title mb-0">ルアー一覧</h1>
    <%= link_to new_lure_path, class: "btn-primary text-sm py-2 px-4" do %>
      + 追加
    <% end %>
  </div>

  <%# フィルタータブ %>
  <div class="flex gap-2 overflow-x-auto pb-1">
    <%= link_to "すべて", lures_path,
          class: "flex-shrink-0 px-3 py-1.5 rounded-full text-sm font-medium #{params[:type].blank? ? 'bg-water-600 text-white' : 'bg-pebble-100 text-pebble-600'}" %>
    <% Lure.lure_types.each_key do |type| %>
      <%= link_to Lure::LURE_TYPE_LABELS[type], lures_path(type: type),
            class: "flex-shrink-0 px-3 py-1.5 rounded-full text-sm font-medium #{params[:type] == type ? 'bg-water-600 text-white' : 'bg-pebble-100 text-pebble-600'}" %>
    <% end %>
  </div>

  <% if @lures.empty? %>
    <div class="card text-center py-10">
      <p class="text-pebble-400 text-sm mb-2">ルアーが登録されていません</p>
      <%= link_to "最初のルアーを登録する →", new_lure_path, class: "text-water-600 text-sm font-medium" %>
    </div>
  <% else %>
    <div class="space-y-2">
      <% @lures.each do |lure| %>
        <%= link_to lure_path(lure), class: "card flex items-center gap-3 hover:border-water-200 transition-colors" do %>
          <%# カラーサークル %>
          <div class="relative flex-shrink-0">
            <div class="w-12 h-12 rounded-xl border border-pebble-100 overflow-hidden grid grid-rows-2">
              <div style="background-color: <%= lure.color_front %>"></div>
              <div style="background-color: <%= lure.color_back %>"></div>
            </div>
          </div>
          <div class="min-w-0 flex-1">
            <p class="font-semibold text-pebble-800 text-sm truncate"><%= lure.name %></p>
            <% if lure.manufacturer.present? %>
              <p class="text-xs text-pebble-400 truncate"><%= lure.manufacturer %></p>
            <% end %>
            <div class="flex items-center gap-2 mt-0.5">
              <span class="badge badge-water"><%= lure.lure_type_label %></span>
              <% if lure.weight %>
                <span class="text-xs text-pebble-400"><%= lure.weight %>g</span>
              <% end %>
            </div>
          </div>
          <div class="flex-shrink-0 text-right">
            <p class="text-xs text-pebble-400"><%= lure.buoyancy_label %></p>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
