<% content_for :title, "プロフィール編集 | AreaGo" %>
<div class="pt-2">
  <div class="flex items-center gap-3 mb-5">
    <%= link_to users_profile_path, class: "text-water-600" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
    <% end %>
    <h1 class="page-title mb-0">プロフィール編集</h1>
  </div>
  <%= form_with model: @user, url: users_profile_path, method: :patch, class: "space-y-4" do |f| %>
    <div>
      <%= f.label :username, "ニックネーム", class: "form-label" %>
      <%= f.text_field :username, class: "form-input" %>
    </div>
    <%= f.submit "更新する", class: "btn-primary w-full text-center cursor-pointer" %>
  <% end %>
</div>
