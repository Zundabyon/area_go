<% content_for :title, "マイページ | AreaGo" %>
<div class="pt-2 space-y-4">
  <h1 class="page-title">マイページ</h1>
  <div class="card">
    <p class="text-sm text-pebble-500">ニックネーム</p>
    <p class="font-semibold text-pebble-800 mt-1"><%= current_user.username %></p>
    <p class="text-sm text-pebble-500 mt-3">メールアドレス</p>
    <p class="font-semibold text-pebble-800 mt-1"><%= current_user.email %></p>
  </div>
  <div class="grid grid-cols-2 gap-3">
    <div class="card text-center">
      <p class="text-2xl font-bold text-water-700"><%= current_user.catch_records.count %></p>
      <p class="text-xs text-pebble-400 mt-1">釣果記録</p>
    </div>
    <div class="card text-center">
      <p class="text-2xl font-bold text-water-700"><%= current_user.lures.count %></p>
      <p class="text-xs text-pebble-400 mt-1">ルアー数</p>
    </div>
  </div>
  <%= link_to edit_users_profile_path, class: "btn-secondary w-full text-center block" do %>編集<% end %>
  <%= button_to destroy_user_session_path, method: :delete, class: "w-full text-center text-sm text-red-500 py-2 mt-2 hover:underline" do %>ログアウト<% end %>
</div>
