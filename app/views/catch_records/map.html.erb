<% content_for :title, "釣果マップ | AreaGo" %>

<div class="pt-2 space-y-4" data-turbo-cache="false">
  <div class="flex items-center gap-3">
    <%= link_to catch_records_path, class: "text-water-600" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
    <% end %>
    <h1 class="page-title mb-0">釣果マップ</h1>
  </div>

  <div data-controller="map"
       data-map-mode-value="view"
       data-map-api-key-value="<%= ENV['GOOGLE_MAPS_API_KEY'] %>"
       data-map-pins-value="<%= @catch_records.as_json(only: [:id, :latitude, :longitude, :size_cm, :fish_species], include: { facility: { only: [:name] }, lure: { only: [:name] } }).to_json %>">
    <div data-map-target="container" class="w-full rounded-2xl overflow-hidden border border-pebble-200 shadow-sm" style="height: calc(100vh - 200px);"></div>
  </div>
</div>
