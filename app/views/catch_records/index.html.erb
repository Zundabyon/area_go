<% content_for :title, "釣果一覧 | AreaGo" %>

<div class="space-y-4 pt-2">
  <div class="flex items-center justify-between">
    <h1 class="page-title mb-0">釣果一覧</h1>
    <div class="flex gap-2">
      <%= link_to map_catch_records_path, class: "p-2 text-water-600" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
        </svg>
      <% end %>
    </div>
  </div>

  <% if @catch_records.empty? %>
    <div class="card text-center py-10">
      <p class="text-pebble-400 text-sm mb-2">釣果がまだ記録されていません</p>
      <%= link_to "最初の釣果を記録する →", new_catch_record_path, class: "text-water-600 text-sm font-medium" %>
    </div>
  <% else %>
    <div class="space-y-2">
      <% @catch_records.each do |record| %>
        <%= link_to catch_record_path(record), class: "card block hover:border-water-200 transition-colors" do %>
          <div class="flex items-start gap-3">
            <div class="w-10 h-10 bg-water-50 rounded-xl flex items-center justify-center flex-shrink-0 text-lg">🐟</div>
            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-2">
                <p class="font-semibold text-pebble-800"><%= record.fish_species %></p>
                <% if record.size_cm %>
                  <span class="badge badge-water"><%= record.size_cm %>cm</span>
                <% end %>
              </div>
              <p class="text-xs text-pebble-400 mt-0.5">
                <%= record.facility.name %>
                · <%= record.caught_at.strftime("%Y/%m/%d %H:%M") %>
              </p>
              <% if record.stocking_time %>
                <p class="text-xs text-pebble-400">
                  放流: <%= record.stocking_time.strftime("%H:%M") %>
                </p>
              <% end %>
              <% if record.lure %>
                <div class="flex items-center gap-2 mt-1">
                  <div class="flex gap-0.5">
                    <span class="w-3 h-3 rounded-full border border-pebble-100" style="background-color: <%= record.lure.color_front %>"></span>
                    <span class="w-3 h-3 rounded-full border border-pebble-100" style="background-color: <%= record.lure.color_back %>"></span>
                  </div>
                  <span class="text-xs text-pebble-500 truncate"><%= record.lure.name %></span>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
